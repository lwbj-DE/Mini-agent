# ============================================================
# Mini Agent — 配置文件
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- LLM API ---
api_key=sk-your-api-key-here
base_url=https://api.xiaomimimo.com/v1
model=mimo-v2.5-pro
temperature=0.7
max_tokens=4096

# --- Agent ---
max_steps=10

# --- 上下文压缩 ---
compression_enabled=true
compression_trigger_fraction=0.7
compression_keep_messages=20
compression_summary_max_chars=500
model_max_input_tokens=32768
